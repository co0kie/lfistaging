---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<section class="bg-gray-50/50 py-16 md:py-24">
	<div class="site-container mx-auto px-4">
		<div class="mx-auto max-w-4xl">
			<h2 class="mb-8 flex items-center gap-3 text-3xl font-bold text-gray-900 md:text-4xl">
				<span class="bg-primary h-8 w-2 rounded-full"></span>
				{title}
			</h2>
			<div class="prose prose-lg max-w-none leading-relaxed whitespace-pre-wrap text-gray-700">
				<slot />
			</div>
		</div>
	</div>
</section>

<style is:inline>
	.prose h3 {
		@apply mt-8 mb-4 text-2xl font-bold text-gray-900;
	}
	.prose p {
		@apply mb-6;
	}
	.prose ul {
		@apply my-6 ml-6 list-outside list-disc space-y-2;
	}
	.prose li {
		@apply pl-1;
	}
</style>
