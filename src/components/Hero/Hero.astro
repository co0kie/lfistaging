---
import Admonition from "@components/Admonition/Admonition.astro";
import Button from "@components/Button/Button.astro";
import Category from "@components/Category/Category.astro";
import { Image } from "astro:assets";
import { ArrowRight, CarFront, Radar, ShoppingCart } from "lucide-react";
import Homepage from "@images/Homepage.png";
import Feeds from "./Feeds.astro";
import FeedsSkeleton from "./FeedsSkeleton.astro";

interface Props {
	title: string;
	subtitle: string;
	ctaText: string;
	ctaLink: string;
	secondaryCtaText: string;
	secondaryCtaLink: string;
	nextClassStartingSoonTitle?: string;
	nextClassStartingSoonSubtitle?: string;
	nextClassStartingArray?: string[];
}

const {
	title,
	subtitle,
	ctaText,
	ctaLink,
	secondaryCtaText,
	secondaryCtaLink,
	nextClassStartingSoonTitle,
	nextClassStartingSoonSubtitle,
	nextClassStartingArray,
} = Astro.props as Props;
---

<section
	id="hero"
	class="relative flex w-full items-center justify-center pb-14 text-white md:h-[800px]"
>
	<Image
		src={Homepage}
		alt={title}
		class="object-cover"
		priority
		style={{
			position: "absolute",
			height: "100%",
			width: "100%",
			left: 0,
			top: 0,
			right: 0,
			bottom: 0,
			color: "transparent",
		}}
	/>

	<div class="bg-blue/70 absolute inset-0"></div>
	<div class="site-container flex w-full flex-col items-center justify-between gap-14 md:flex-row">
		<div class="relative z-10 mx-auto mt-12 max-w-4xl space-y-6 text-center md:w-3/5 md:text-left">
			<div
				class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="lucide lucide-shield-check text-primary-600"
					aria-hidden="true"
					><path
						d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
					></path><path d="m9 12 2 2 4-4"></path></svg
				><span class="text-xs font-bold tracking-[0.2em] text-gray-300 uppercase"
					>NRA Certified Training</span
				>
			</div>
			<h1
				class="font-headline animate-fade-in-up mb-6 text-4xl font-bold tracking-wide opacity-0 md:text-6xl md:leading-[1.3] lg:text-7xl lg:leading-[1.3]"
			>
				{title}
			</h1>
			<p
				class="animate-fade-in-up animation-delay-300 mb-8 text-lg text-blue-100 opacity-0 md:mb-10 md:text-xl"
			>
				{subtitle}
			</p>
			<div
				class="animate-fade-in-up animation-delay-600 mx-auto flex max-w-max flex-col gap-4 opacity-0 sm:flex-row md:mx-0"
			>
				<Button variant="primary" href={ctaLink} class="mx-auto gap-4 px-5 py-4 text-base">
					<Radar />
					{ctaText}
				</Button>

				<Button
					variant="ghost"
					href={secondaryCtaLink}
					arrow="right"
					class="gap-2 text-base text-white">{secondaryCtaText}</Button
				>
			</div>
		</div>
		<div class="relative z-10 w-full space-y-4 md:w-2/5">
			<!-- Next -->
			<a
				href="/rules-to-purchase-your-first-gun-for-home-defense"
				class="group border-primary-600 hover:border-orange/40 hover:bg-blue-dark/90 relative mx-auto block max-w-md rounded-2xl border bg-transparent text-left shadow-[0_18px_45px_rgba(15,23,42,0.28)] backdrop-blur-sm transition duration-300 hover:-translate-y-1 md:mr-4 md:ml-auto"
			>
				<div
					class="bg-blue ring-orange/15 flex items-center gap-2 rounded-[1rem] border border-white/10 p-4 text-white ring-1"
				>
					<!-- <div
						class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-orange text-blue-dark shadow-md"
					>
						<ShoppingCart className="h-5 w-5" />
					</div> -->
					<div class="min-w-0 flex-1">
						<p
							class="font-headline text-center text-base font-semibold tracking-[0.08em] text-white uppercase"
						>
							Rules to Purchase Your First Gun
						</p>
						<p class="mt-1 text-center text-sm text-slate-300">Step-by-step guide for new buyers</p>
					</div>
					<div
						class="text-primary-600 group-hover:bg-orange group-hover:text-blue-dark bg-orange/15 flex h-9 w-9 shrink-0 items-center justify-center rounded-full transition duration-300"
					>
						<ArrowRight className="h-4 w-4" />
					</div>
				</div>
			</a>
			<Feeds
				server:defer
				nextClassStartingSoonTitle={nextClassStartingSoonTitle}
				nextClassStartingSoonSubtitle={nextClassStartingSoonSubtitle}
				nextClassStartingArray={nextClassStartingArray}
			>
				<FeedsSkeleton slot="fallback" />
			</Feeds>
		</div>
	</div>
</section>

<style>
	@keyframes fade-in-up {
		0% {
			opacity: 0;
			transform: translateY(20px);
		}
		100% {
			opacity: 1;
			transform: translateY(0);
		}
	}
	.animate-fade-in-up {
		animation: fade-in-up 0.6s ease-out forwards;
	}
	.animation-delay-300 {
		animation-delay: 300ms;
	}
	.animation-delay-600 {
		animation-delay: 600ms;
	}
	.animation-fill-forwards {
		animation-fill-mode: forwards;
	}
</style>
