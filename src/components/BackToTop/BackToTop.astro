---
import { ArrowUp } from "lucide-react";
---

<button
	id="back-to-top"
	class="bg-orange text-blue-dark fixed right-6 bottom-6 z-50 flex h-12 w-12 translate-y-20 flex-col items-center justify-center rounded-full opacity-0 shadow-xl transition-all duration-300 pointer-events-none hover:bg-orange/90 hover:scale-110 focus:outline-none focus:ring-2 focus:ring-orange focus:ring-offset-2"
	aria-label="Back to top"
>
	<ArrowUp className="h-6 w-6" />
</button>

<script>
	const setupBackToTop = () => {
		const backToTopButton = document.getElementById("back-to-top");

		if (backToTopButton) {
			const toggleVisibility = () => {
				if (window.scrollY > 400) {
					backToTopButton.classList.remove("opacity-0", "translate-y-20", "pointer-events-none");
					backToTopButton.classList.add("opacity-100", "translate-y-0", "cursor-pointer");
				} else {
					backToTopButton.classList.add("opacity-0", "translate-y-20", "pointer-events-none");
					backToTopButton.classList.remove("opacity-100", "translate-y-0", "cursor-pointer");
				}
			};

			// Initial check and event listener
			window.addEventListener("scroll", toggleVisibility);
			toggleVisibility();

			backToTopButton.addEventListener("click", () => {
				window.scrollTo({ top: 0, behavior: "smooth" });
			});
		}
	};

	// Setup after Astro page transitions
	document.addEventListener("astro:page-load", setupBackToTop);
</script>
